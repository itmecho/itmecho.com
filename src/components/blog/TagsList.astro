---
import { getCollection } from "astro:content";

import TagLink from "./TagLink.astro";

const posts = await getCollection("blog");
const uniqueTags = new Set<string>();
for (const p of posts) {
  for (const t of p.data.tags) {
    uniqueTags.add(t);
  }
}
const tags = Array.from(uniqueTags.values()).sort((a, b) => a.localeCompare(b));
---

<section>
  <h3>Tags</h3>
  <ul>
    {
      tags.map((t) => (
        <li>
          <TagLink text={t} size="lg" />
        </li>
      ))
    }
  </ul>
</section>

<style>
  h3 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }
  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;

    li {
      margin: 0;
      padding: 0;
      list-style: none;
    }
  }
  ul li a {
    text-decoration: none;
  }
</style>
