---
import { presentDate } from "#/utils/present";
import type { CollectionEntry } from "astro:content";
import { isEqual } from "date-fns";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const updatedDate =
  !!post.data.pubDate &&
  !!post.data.updatedDate &&
  !isEqual(post.data.pubDate, post.data.updatedDate) &&
  post.data.updatedDate;
---

{post.data.pubDate ? presentDate(post.data.pubDate) : "draft"}{
  updatedDate && ` (updated ${presentDate(updatedDate)})`
}
