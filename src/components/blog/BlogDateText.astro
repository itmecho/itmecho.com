---
import { presentDate } from "#/utils/present";
import { getPubDate } from "#/utils/blog";
import type { CollectionEntry } from "astro:content";
import { isEqual } from "date-fns";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const pubDate =  getPubDate(post);
const updatedDate =
  !!post.data.updatedDate &&
  !isEqual(pubDate, post.data.updatedDate) &&
  post.data.updatedDate;
---

<time>
  {presentDate(pubDate)}{
    updatedDate && ` (updated ${presentDate(updatedDate)})`
  }
</time>
