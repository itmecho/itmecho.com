---
import ResetStyles from "#/components/styles/ResetStyles.astro";
import PageLoadThemeScript from "#/components/styles/PageLoadThemeScript.astro";
import CssVars from "#/components/styles/CssVars.astro";
import { Font } from "astro:assets";
import ThemeSwitcher from "#/components/styles/ThemeSwitcher.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>itmecho.com</title>
    <Font cssVariable="--font-sans" />
    <Font cssVariable="--font-pixelated" />
    <ResetStyles />
    <CssVars />
  </head>
  <body data-theme="dark">
    <PageLoadThemeScript />
    <slot />
    <ThemeSwitcher />
  </body>
</html>

<style>
  html,
  body {
    height: 100%;
  }
  body {
    background-color: var(--base);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 16px;

    &.transition {
      transition:
        background-color 0.2s ease-in-out,
        color 0.2s ease-in-out;
    }
  }
</style>
