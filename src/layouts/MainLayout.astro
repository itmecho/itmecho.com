---
import NavLinks from "#/components/nav-links/NavLinks.astro";
import BaseLayout from "./BaseLayout.astro";
---

<BaseLayout>
  <div class="page-container">
    <header>
      <a href="/"><p class="site-title">itmecho</p></a>
      <NavLinks />
    </header>
    <main>
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 800px;
    margin: 0 auto;
  }

  header {
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;

    > a {
      text-decoration: none;
    }

    .site-title {
      font-family: var(--font-pixelated);
      color: var(--text);
      font-size: 2rem;
    }
  }

  main {
    padding: 2rem;
  }
</style>
