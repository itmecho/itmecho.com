---
import { render } from "astro:content";
import { getCollection } from "astro:content";

import PostDateText from "#/components/blog/BlogDateText.astro";
import BlogTitle from "#/components/blog/BlogTitle.astro";
import TagLink from "#/components/blog/TagLink.astro";
import Icon from "#/components/icons/Icon.astro";
import MainLayout from "#/layouts/MainLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<MainLayout>
  <div class="content-wrapper">
    <BlogTitle subtitle={post.data.title} />
    <div class="metadata">
      <p>
        <PostDateText post={post} />
      </p>
      <div class="tags">
        Tags: {post.data.tags.map((t) => <TagLink text={t} />)}
      </div>
    </div>
    {
      post.data.showContents && (
        <>
          <nav>
            <h2>Contents</h2>
            {headings.map((h) => (
            <a href={`#${h.slug}`} style={{marginLeft: `${h.depth-2}rem`}}>{h.text}</a>
            ))}
          </nav>
          <hr />
        </>
      )
    }
    <Content />
    <button
      id="back-to-top"
      onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
    >
      <Icon icon="chevron-double-up" />
    </button>
  </div>
  <script>
    (() => {
      const btt = document.querySelector<HTMLButtonElement>("#back-to-top");
      if (btt) {
        document.addEventListener("scroll", () => {
          if (window.scrollY > 100) {
            btt.classList.add("visible");
          } else {
            btt.classList.remove("visible");
          }
        });
      }
    })();
  </script>
</MainLayout>

<style>
  .content-wrapper {
    h1 {
      margin-bottom: 3rem;
      font-size: 3rem;
      font-weight: 300;
    }
    h2 {
      margin: 2rem 0 1rem;
      font-size: 2.5rem;
      font-weight: 300;
    }
    h3 {
      margin: 2rem 0 1rem;
      font-size: 2rem;
      font-weight: 300;
    }
    .metadata {
      margin-bottom: 3rem;
      font-size: 1.2rem;

      .tags {
        margin-top: 0.5rem;
        display: flex;
        gap: 0.5rem;
        align-items: center;
      }
    }

    > nav a {
      display: block;
      margin-bottom: 0.5rem;
      color: var(--green);

      &:last-of-type {
        margin-bottom: 0;
      }
    }
    > hr {
      margin: 2rem 0;
      border-bottom: 1px solid var(--surface2);
    }
    > p,
    > ul {
      font-size: 1.2rem;
    }
    > p {
      margin: 1rem 0;
      line-height: 2rem;
    }
    > p > a {
      color: var(--green);

      &:visited {
        color: var(--teal);
      }
    }
    > ul {
      margin-left: 2rem;

      li {
        margin-bottom: 0.5rem;
        list-style: disc;
        padding-left: 1rem;
      }
    }
    > pre.astro-code {
      margin: 2rem 0;
      padding: 2rem;
      border-radius: var(--radius-md);
      line-height: 1.5rem;
    }
    > img {
      margin: 0 auto;
    }
    > p > code {
      display: inline-block;
      padding: 0.3rem 0.4rem;
      background-color: var(--surface1);
      border-radius: var(--radius-md);
      font-size: 1rem;
      line-height: 1rem;
    }
  }

  #back-to-top {
    display: none;
    opactity: 0;
    position: fixed;
    bottom: 1rem;
    right: 4rem;
    padding: 0.5rem;
    border-radius: 0.4rem;
    background-color: var(--surface0);
    cursor: pointer;
    color: var(--text);
    transition:
      opacity var(--transition),
      background-color var(--transition),
      color var(--transition);

    &.visible {
      display: inline-block;
      opacity: 1;

      &:hover {
        background-color: var(--surface1);
      }
    }
  }
</style>
